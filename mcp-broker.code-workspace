{
    "folders": [
        { "name": "📦 mcp-broker (root)", "path": "." },
        { "name": "🟢 node", "path": "node" },
        { "name": "🔷 dotnet", "path": "dotnet" } 
    ],
    "settings": {
        "files.exclude": {
            "node": true,
            "dotnet": true,
            "**/node_modules": true,
            "**/bin": true,
            "**/obj": true,
            "**/dist": true
        },
        "search.exclude": {
            "**/node_modules": true,
            "**/dist": true,
            "**/bin": true,
            "**/obj": true
        },
        "typescript.tsdk": "node/node_modules/typescript/lib",
        "eslint.workingDirectories": [
            { "directory": "node", "changeProcessCWD": true }
        ],
        "dotnet.defaultSolution": "dotnet/McpBroker.sln",
        "files.eol": "\n",
        "liveServer.settings.multiRootWorkspaceName": "📦 mcp-broker (root)"
    },
    "extensions": {
        "recommendations": [
            "dbaeumer.vscode-eslint",
            "esbenp.prettier-vscode",
            "ms-dotnettools.csharp",
            "ms-dotnettools.csdevkit",
            "editorconfig.editorconfig"
        ]
    }
}
