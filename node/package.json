{
    "name": "@cyanmycelium/mcp-broker",
    "version": "0.2.0",
    "description": "WebSocket-based Model Context Protocol broker. Aggregates multiple MCP providers behind a single endpoint with stdio, SSE, and Streamable HTTP client transports.",
    "type": "module",
    "license": "Apache-2.0",
    "author": "Guillaume Pelletier (CyanMycelium)",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/pandaGaume/mcp-broker.git",
        "directory": "node"
    },
    "homepage": "https://github.com/pandaGaume/mcp-broker#readme",
    "bugs": {
        "url": "https://github.com/pandaGaume/mcp-broker/issues"
    },
    "keywords": [
        "mcp",
        "model-context-protocol",
        "broker",
        "tunnel",
        "websocket",
        "jsonrpc",
        "cyanmycelium"
    ],
    "engines": {
        "node": ">=20.11.0"
    },
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
        "mcp-broker": "./dist/bin.js"
    },
    "files": [
        "dist",
        "src",
        "scripts",
        ".mcp-broker.example",
        "LICENSE",
        "README.md"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "npm run clean && npm run compile && npm run copy:assets",
        "clean": "rimraf dist tsconfig.build.tsbuildinfo",
        "compile": "tsc -b tsconfig.build.json",
        "copy:assets": "node scripts/copy-assets.mjs",
        "watch": "tsc -b tsconfig.build.json -w",
        "start": "node dist/bin.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
        "lint:fix": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --fix",
        "format": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
        "format:fix": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
        "gen-cert": "node scripts/gen-cert.mjs",
        "prepublishOnly": "npm run lint && npm run build && npm test"
    },
    "dependencies": {
        "@cyanmycelium/mcp-core": "^0.2.0",
        "open": "^11.0.0",
        "ws": "^8.18.0"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "@types/ws": "^8.5.0",
        "@typescript-eslint/eslint-plugin": "^7.0.0",
        "@typescript-eslint/parser": "^7.0.0",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.1.0",
        "prettier": "^3.2.0",
        "rimraf": "~6.0.1",
        "selfsigned": "^2.4.1",
        "tslib": "^2.8.1",
        "typescript": "^5.4.0",
        "vitest": "^1.6.0"
    }
}
