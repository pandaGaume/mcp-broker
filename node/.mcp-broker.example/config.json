{
    "port": 3001,
    "host": "0.0.0.0",
    "locale": "fr",
    "brokerName": "broker-eu-west",

    "paths": {
        "provider": "/provider",
        "client":   "/",
        "mcp":      "/mcp"
    },

    "tls": {
        "cert": "certs/cert.pem",
        "key":  "certs/key.pem"
    },

    "www": {
        "open": false,
        "mounts": [
            { "urlPrefix": "/", "dir": "www" }
        ]
    },

    "stdioUpstreams": [
        {
            "name":    "fs",
            "command": "npx",
            "args":    ["-y", "@modelcontextprotocol/server-filesystem", "/data"]
        }
    ],

    "mcpbBundles": [
        {
            "name":       "weather",
            "path":       "bundles/weather.mcpb",
            "publicKey":  "bundles/mcpb-signing.pub.pem",
            "signature":  "bundles/weather.mcpb.sig",
            "userConfig": { "apiKey": "your-key-here" },
            "aggregate":  true
        }
    ]
}
